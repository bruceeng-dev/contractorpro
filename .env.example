# Copy this file to .env and update the values

# Core Settings
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://contractor:password@localhost:5432/contractorpro
# For development, you can also use SQLite:
# DATABASE_URL=sqlite:///contractorpro.db

# File Upload Settings
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800  # 50MB in bytes

# Email Configuration (for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@contractorpro.com

# Optional Features
ENABLE_PHOTO_PROGRESS=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_ESTIMATES=True

# OpenAI Integration (for AI contract generation)
OPENAI_API_KEY=your-openai-api-key-here
# Leave blank to use rule-based contract generation

# Deployment Settings (for production)
# Set to 'production' when deploying
# FLASK_ENV=production
# DEBUG=False
# Use PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@host:port/database